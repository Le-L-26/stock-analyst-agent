# Copy this file to ".env" and paste your real values.

# --- Claude (required) -------------------------------------------------------
# Get one at: https://console.anthropic.com/settings/keys
# The @ai-sdk/anthropic provider reads this automatically on the server.
ANTHROPIC_API_KEY=sk-ant-...

# --- Data bridge (required in production) ------------------------------------
# Where the Python stock-data bridge (in ../ai-hedge-fund) is listening.
# Local default is http://127.0.0.1:8077. In production set this to the bridge's
# public URL, e.g. https://stock-bridge.onrender.com
# DATA_BRIDGE_URL=http://127.0.0.1:8077

# Shared secret the Nuxt server sends to the bridge as X-Bridge-Token. Must match
# BRIDGE_TOKEN configured on the bridge. Leave empty for purely-local dev.
# BRIDGE_TOKEN=

# --- Public access gate (set in production) ----------------------------------
# When set, the whole site is locked behind HTTP Basic Auth. Visitors get a
# browser popup and type this password (username is ignored). Leave empty in
# local dev to disable the gate.
# SITE_PASSWORD=
